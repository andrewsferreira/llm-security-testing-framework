# Copy to .env and adjust as needed. Never commit a real .env file.

# --- Lab target (lab/app) ---
# Controls which behavior profile the local lab FastAPI app exposes.
# "vulnerable" demonstrates unmitigated LLM security issues for testing purposes.
# "hardened" demonstrates the corresponding mitigations.
LAB_MODE=vulnerable
LAB_HOST=0.0.0.0
LAB_PORT=8000

# --- Framework safety gates ---
# Must be explicitly set to "true" to allow scanning targets outside localhost/private ranges.
LLMSEC_ALLOW_EXTERNAL_TARGETS=false

# Optional override for where payload YAML files are loaded from.
# Defaults to the packaged `payloads/` directory if unset.
# LLMSEC_PAYLOADS_DIR=./payloads

# --- Optional external LLM provider adapter (NOT required to use this framework) ---
# Only used by src/llmsec/targets/provider_adapter.py if you choose to target
# a real provider API directly instead of your own HTTP endpoint.
# Leave unset to keep everything fully local and free of paid API dependencies.
# The env var name itself is arbitrary — whatever you set as `auth_token_env` in your config;
# these are just illustrative examples for each of the 8 supported providers.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# AZURE_OPENAI_API_KEY=
# MISTRAL_API_KEY=
# OPENROUTER_API_KEY=
# OLLAMA_API_KEY=              # usually unset entirely — see docs/target-integration.md
# AWS_ACCESS_KEY_ID=           # bedrock only, paired with AWS_SECRET_ACCESS_KEY below
# AWS_SECRET_ACCESS_KEY=       # bedrock only
# AWS_SESSION_TOKEN=           # bedrock only, optional (temporary/STS credentials)
