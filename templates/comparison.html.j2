<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>llmsec campaign comparison</title>
<style>
  :root {
    --bg: #0f1115; --panel: #161923; --border: #2a2f3d; --text: #e6e8ee; --muted: #9aa3b2;
    --accent: #5b8cff; --critical: #e5484d; --high: #f2994a; --medium: #f2c94c; --low: #6fcf97;
    --pass: #34d399;
  }
  * { box-sizing: border-box; }
  body {
    margin: 0; padding: 2rem; background: var(--bg); color: var(--text);
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
    line-height: 1.5;
  }
  h1, h2, h3 { font-weight: 600; }
  h1 { font-size: 1.5rem; }
  h2 { font-size: 1.15rem; margin-top: 2.5rem; border-bottom: 1px solid var(--border); padding-bottom: .4rem; }
  .banner {
    background: #2a1a1c; border: 1px solid var(--critical); color: #ffd7d7;
    padding: .75rem 1rem; border-radius: 6px; margin-bottom: 1.5rem; font-size: .9rem;
  }
  table { border-collapse: collapse; width: 100%; margin: 1rem 0; }
  th, td { text-align: left; padding: .5rem .6rem; border-bottom: 1px solid var(--border); font-size: .9rem; }
  th { color: var(--muted); font-weight: 600; font-size: .78rem; text-transform: uppercase; }
  .muted { color: var(--muted); }
  .chart { margin: 1rem 0; }
  .chart svg { max-width: 100%; height: auto; display: block; }
  footer { margin-top: 3rem; color: var(--muted); font-size: .8rem; border-top: 1px solid var(--border); padding-top: 1rem; }
</style>
</head>
<body>
  <h1>llmsec campaign comparison</h1>
  <div class="banner">
    Use only against systems you own or are explicitly authorized to test. See docs/ethical-use.md.
  </div>
  <p class="muted">Comparing {{ comparison.entries|length }} campaign(s).</p>

  <h2>Overview</h2>
  <table>
    <thead>
      <tr>
        <th>Label</th><th>Suite</th><th>Total</th><th>Passed</th><th>Failed</th>
        <th>Inconclusive</th><th>Errors</th><th>Avg risk</th>
      </tr>
    </thead>
    <tbody>
      {% for entry in comparison.entries %}
      <tr>
        <td>{{ entry.label }}</td>
        <td>{{ entry.suite }}</td>
        <td>{{ entry.total_tests }}</td>
        <td>{{ entry.passed }}</td>
        <td>{{ entry.failed }}</td>
        <td>{{ entry.inconclusive }}</td>
        <td>{{ entry.errors }}</td>
        <td>{{ "%.2f"|format(entry.average_finding_risk_score) }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% if overview_chart %}
  <div class="chart">{{ overview_chart | safe }}</div>
  {% endif %}

  <h2>Findings by category</h2>
  {% if not comparison.categories %}
  <p class="muted">No findings in any compared campaign.</p>
  {% else %}
  <table>
    <thead>
      <tr>
        <th>Category</th>
        {% for entry in comparison.entries %}<th>{{ entry.label }}</th>{% endfor %}
      </tr>
    </thead>
    <tbody>
      {% for category in comparison.categories %}
      <tr>
        <td>{{ category }}</td>
        {% for entry in comparison.entries %}
        <td>{{ entry.category_distribution_findings.get(category, 0) }}</td>
        {% endfor %}
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% for category in comparison.categories %}
  {% if category_charts.get(category) %}
  <h3>{{ category }}</h3>
  <div class="chart">{{ category_charts[category] | safe }}</div>
  {% endif %}
  {% endfor %}
  {% endif %}

  <h2>Severity distribution (findings only)</h2>
  <table>
    <thead>
      <tr>
        <th>Severity</th>
        {% for entry in comparison.entries %}<th>{{ entry.label }}</th>{% endfor %}
      </tr>
    </thead>
    <tbody>
      {% for field in ["critical", "high", "medium", "low"] %}
      <tr>
        <td>{{ field }}</td>
        {% for entry in comparison.entries %}
        <td>{{ entry.severity_distribution_findings[field] }}</td>
        {% endfor %}
      </tr>
      {% endfor %}
    </tbody>
  </table>

  <footer>Generated by llmsec. No external stylesheets, fonts, or scripts are loaded by this page.</footer>
</body>
</html>
