<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>llmsec dashboard</title>
<style>
  :root {
    --bg: #0f1115; --panel: #161923; --border: #2a2f3d; --text: #e6e8ee; --muted: #9aa3b2;
    --accent: #5b8cff; --critical: #e5484d; --high: #f2994a; --medium: #f2c94c; --low: #6fcf97;
    --pass: #34d399;
  }
  * { box-sizing: border-box; }
  body {
    margin: 0; padding: 2rem; background: var(--bg); color: var(--text);
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
    line-height: 1.5;
  }
  h1, h2 { font-weight: 600; }
  h1 { font-size: 1.5rem; }
  h2 { font-size: 1.15rem; margin-top: 2.5rem; border-bottom: 1px solid var(--border); padding-bottom: .4rem; }
  .banner {
    background: #2a1a1c; border: 1px solid var(--critical); color: #ffd7d7;
    padding: .75rem 1rem; border-radius: 6px; margin-bottom: 1.5rem; font-size: .9rem;
  }
  .cards { display: flex; gap: 1rem; flex-wrap: wrap; margin: 1rem 0; }
  .card {
    background: var(--panel); border: 1px solid var(--border); border-radius: 8px;
    padding: 1rem 1.25rem; min-width: 140px;
  }
  .card .value { font-size: 1.6rem; font-weight: 700; }
  .card .label { color: var(--muted); font-size: .8rem; text-transform: uppercase; letter-spacing: .04em; }
  table { border-collapse: collapse; width: 100%; margin: 1rem 0; }
  th, td { text-align: left; padding: .5rem .6rem; border-bottom: 1px solid var(--border); font-size: .9rem; }
  th { color: var(--muted); font-weight: 600; font-size: .78rem; text-transform: uppercase; }
  .muted { color: var(--muted); }
  .chart { margin: 1rem 0; }
  .chart svg { max-width: 100%; height: auto; display: block; }
  footer { margin-top: 3rem; color: var(--muted); font-size: .8rem; border-top: 1px solid var(--border); padding-top: 1rem; }
</style>
</head>
<body>
  <h1>llmsec dashboard</h1>
  <div class="banner">
    Use only against systems you own or are explicitly authorized to test. See docs/ethical-use.md.
  </div>
  <p class="muted">
    Computed fresh from {{ dashboard.total_campaigns }} campaign report(s) found on disk — no
    database, no persistent service. Re-run <code>llmsec dashboard</code> after new scans to
    refresh.
  </p>

  <h2>Overview</h2>
  <div class="cards">
    <div class="card"><div class="value">{{ dashboard.total_campaigns }}</div><div class="label">Campaigns</div></div>
    <div class="card"><div class="value">{{ dashboard.total_tests }}</div><div class="label">Total tests</div></div>
    <div class="card"><div class="value status-failed" style="color:var(--critical);">{{ dashboard.total_findings }}</div><div class="label">Total findings</div></div>
  </div>

  <h2>Trend over time</h2>
  {% if trend_svg %}
  <p class="muted">Failed findings per campaign, oldest to newest (bar 1 = earliest). Bar color reflects that campaign's average finding risk score.</p>
  <div class="chart">{{ trend_svg | safe }}</div>
  {% else %}
  <p class="muted">Not enough data to plot a trend.</p>
  {% endif %}

  <h2>Campaigns</h2>
  <table>
    <thead>
      <tr>
        <th>#</th><th>Label</th><th>Suite</th><th>Started</th><th>Total</th>
        <th>Passed</th><th>Failed</th><th>Inconclusive</th><th>Errors</th><th>Avg risk</th>
      </tr>
    </thead>
    <tbody>
      {% for entry in dashboard.entries %}
      <tr>
        <td>{{ loop.index }}</td>
        <td>{{ entry.label }}</td>
        <td>{{ entry.suite }}</td>
        <td>{{ entry.started_at.isoformat() }}</td>
        <td>{{ entry.total_tests }}</td>
        <td>{{ entry.passed }}</td>
        <td>{{ entry.failed }}</td>
        <td>{{ entry.inconclusive }}</td>
        <td>{{ entry.errors }}</td>
        <td>{{ "%.2f"|format(entry.average_finding_risk_score) }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>

  <h2>Severity distribution (all campaigns, findings only)</h2>
  {% if severity_chart %}
  <div class="chart">{{ severity_chart | safe }}</div>
  {% endif %}

  <h2>Category distribution (all campaigns, findings only)</h2>
  {% if category_chart %}
  <div class="chart">{{ category_chart | safe }}</div>
  {% endif %}

  <footer>Generated by llmsec. No external stylesheets, fonts, or scripts are loaded by this page.</footer>
</body>
</html>
